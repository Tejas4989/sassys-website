# Copy this to .env.local and fill in values
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
AUTH_SECRET=change-me-openssl-rand-base64-32

RESEND_API_KEY=re_...
ADMIN_EMAIL=inquiry@mysassys.com

CLOVER_MERCHANT_ID=
CLOVER_API_KEY=
CLOVER_WEBHOOK_SECRET=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Also expose VAPID public key to the browser for push subscription
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sassys-media
R2_PUBLIC_BASE=https://media.mysassys.com

NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=

# Sentry (optional — create project at sentry.io, free tier: 5k errors/mo)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
